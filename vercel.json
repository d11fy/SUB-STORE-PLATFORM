{
  "crons": [
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/store/:slug*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
